{
  "multipart": [
    {
      "when": {"facing": "north"},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "y": 0}
    },
    {
      "when": {"facing": "south"},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "y": 180}
    },
    {
      "when": {"facing": "east"},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "y": 90}
    },
    {
      "when": {"facing": "west"},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "y": 270}
    },
    {
      "when": {"facing": "up", "axis_along_first": false},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "x": -90, "y": 0}
    },
    {
      "when": {"facing": "up", "axis_along_first": true},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "x": -90, "y": 90}
    },
    {
      "when": {"facing": "down", "axis_along_first": false},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "x": 90, "y": 0}
    },
    {
      "when": {"facing": "down", "axis_along_first": true},
      "apply": {"model": "steamturbine:block/boiler_turbine/boiler_turbine", "x": 90, "y": 270}
    }
  ]
}