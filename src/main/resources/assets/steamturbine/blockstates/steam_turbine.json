{
  "multipart": [
    {
      "when": {"facing": "north"},
      "apply": {"model": "steamturbine:block/turbine/steam_turbine", "y": 0}
    },
    {
      "when": {"facing": "south"},
      "apply": {"model": "steamturbine:block/turbine/steam_turbine", "y": 180}
    },
    {
      "when": {"facing": "east"},
      "apply": {"model": "steamturbine:block/turbine/steam_turbine", "y": 90}
    },
    {
      "when": {"facing": "west"},
      "apply": {"model": "steamturbine:block/turbine/steam_turbine", "y": 270}
    }
  ]
}
